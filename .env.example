# Local development defaults
# Este projeto roda localmente usando a API TACO remota e, em deploy, o alvo oficial e Railway.
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=troque-esta-chave-em-producao
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_SITE_ID=1

# Local DB/cache defaults (production must override)
DATABASE_URL=
DJANGO_DB_SSL_REQUIRE=true
DJANGO_DB_CONN_MAX_AGE=600

REDIS_URL=
CACHE_KEY_PREFIX=nutrients
CACHE_TIMEOUT_SECONDS=300
CACHE_SOCKET_TIMEOUT_SECONDS=5
CACHE_SOCKET_CONNECT_TIMEOUT_SECONDS=5

# API TACO (obrigatoria em qualquer ambiente)
TACO_API_BASE_URL=https://web-production-9a2e7.up.railway.app
TACO_API_ALIMENTOS_READ_ENDPOINT=/alimentos/
# Para escrita pode ser /alimentos/ ou /alimentos/editor/ conforme a API externa.
TACO_API_ALIMENTOS_WRITE_ENDPOINT=/alimentos/
TACO_API_TIMEOUT=8
TACO_API_WRITE_TIMEOUT=10
TACO_SEARCH_CACHE_SECONDS=60
TACO_API_TOKEN=

LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_SECONDS=300

# Optional Gunicorn runtime tuning
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=60
GUNICORN_KEEPALIVE=5

# Production required values (Railway web service)
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=<chave-forte>
# DJANGO_ALLOWED_HOSTS=<seu-servico>.up.railway.app
# DJANGO_CSRF_TRUSTED_ORIGINS=https://<seu-servico>.up.railway.app
# DATABASE_URL=postgresql://user:pass@host:5432/db
# REDIS_URL=redis://default:pass@host:6379
# TACO_API_BASE_URL=https://web-production-9a2e7.up.railway.app
# TACO_API_ALIMENTOS_READ_ENDPOINT=/alimentos/
# TACO_API_ALIMENTOS_WRITE_ENDPOINT=/alimentos/
# TACO_API_TOKEN=<token-de-escrita>
# WEB_CONCURRENCY=2
# GUNICORN_TIMEOUT=60
# GUNICORN_KEEPALIVE=5
